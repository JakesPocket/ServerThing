GHCR_OWNER=jakespocket
SERVERTHING_IMAGE_TAG=dev-local
ARM_BRIDGE_IMAGE_TAG=dev-local
ARM_BRIDGE_API_KEY=dev-change-me
# Use "mock" for synthetic data, or "ssh" to read DockServer ARM files remotely.
ARM_BRIDGE_MODE=mock

# For ARM_BRIDGE_MODE=ssh:
ARM_SSH_HOST=10.0.0.10
ARM_SSH_USER=me
ARM_SSH_KEY_HOST_PATH=/Volumes/500GB Drive/Users/me/.ssh/makemkv_dev_arm
ARM_SETTINGS_PATH=/home/me/docker/acquisition/arm/.MakeMKV/settings.conf
ARM_LOGS_DIR=/home/me/docker/acquisition/arm/logs
ARM_PROGRESS_LOGS_DIR=/home/me/docker/acquisition/arm/logs/progress
ARM_ARM_LOG_PATH=/home/me/docker/acquisition/arm/logs/arm.log
ARM_TRANSCODE_LOG_PATH=/home/me/docker/acquisition/arm/logs/transcode.log
